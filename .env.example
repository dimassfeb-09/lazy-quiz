# Kredensial Moodle / V-Class
MOODLE_USERNAME=
MOODLE_PASSWORD=

# Platform URLs (optional - set for convenience)
MOODLE_URL=
EXAM_URL=

# Provider LLM yang digunakan: 'gemini' atau 'groq'
LLM_PROVIDER="gemini"

# Konfigurasi Google Gemini AI
# Dapatkan API Key di: https://aistudio.google.com/
GEMINI_API_KEY=""
# Model yang digunakan (default: gemini-flash-latest)
GEMINI_MODEL="gemini-flash-latest"

# Konfigurasi Groq AI
# Dapatkan API Key di: https://console.groq.com/
GROQ_API_KEY=""
# Model untuk teks (default: llama-3.3-70b-versatile)
GROQ_MODEL="llama-3.3-70b-versatile"
# Model untuk vision (default: llama-3.2-11b-vision-preview)
GROQ_VISION_MODEL="llama-3.2-11b-vision-preview"

